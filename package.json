{
  "name": "yt2do",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "tsx watch server/index.ts",
    "dev:web": "vite --host 0.0.0.0",
    "build": "tsc -p tsconfig.json && vite build",
    "start": "node dist-server/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@ark-ui/react": "^5.37.1",
    "@base-ui/react": "^1.5.0",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "latest",
    "clsx": "^2.1.1",
    "concurrently": "latest",
    "express": "latest",
    "lucide-react": "^1.17.0",
    "radix-ui": "^1.5.0",
    "react": "latest",
    "react-dom": "latest",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.0",
    "tsx": "latest",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "latest",
    "youtube-transcript": "^1.3.1"
  },
  "devDependencies": {
    "@types/express": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "tw-animate-css": "^1.4.0"
  }
}
